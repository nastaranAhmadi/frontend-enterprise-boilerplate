# Strict dependency resolution — catches phantom deps early in large monorepos.
auto-install-peers=true
strict-peer-dependencies=false

# Isolated node_modules per package — explicit dependency graph, better for Nx caching.
node-linker=isolated

# Hoist only toolchain binaries to workspace root for consistent CLI access.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@nx/*
public-hoist-pattern[]=nx

# Reproducible installs across CI and local environments.
prefer-frozen-lockfile=true
