{
  "name": "@enterprise/frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Production-grade frontend monorepo foundation for large-scale e-commerce platforms.",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "setup:clean": "pnpm reset",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "test:no-daemon": "NX_DAEMON=false nx run-many -t test",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint -- --fix",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:validate": "pnpm affected:typecheck && pnpm affected:build",
    "affected:no-daemon": "NX_DAEMON=false nx affected",
    "reset": "nx reset",
    "validate:boundaries": "node scripts/validate-boundaries.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,css,scss,yaml,yml}": "prettier --write",
    "*.{js,mjs,cjs,ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@enterprise/eslint-config": "workspace:*",
    "@nx/eslint": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/react": "23.0.1",
    "@nx/storybook": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/addon-a11y": "10.4.6",
    "@swc/helpers": "~0.5.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
