{
  "extends": "@enterprise/tsconfig/library-react",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/test-setup.ts",
    "src/vitest-env.d.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.stories.tsx",
    "src/**/*.stories.ts",
    "**/*.stories.ts",
    "**/*.stories.js",
    "**/*.stories.jsx",
    "**/*.stories.tsx"
  ],
  "references": [
    { "path": "../types/tsconfig.lib.json" },
    { "path": "../design-tokens/tsconfig.lib.json" },
    { "path": "../shared/tsconfig.lib.json" },
    { "path": "../theme/tsconfig.lib.json" }
  ]
}
