{
  "extends": ["../../tsconfig.base.json", "@enterprise/tsconfig/library"],
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.lib.tsbuildinfo",
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    { "path": "../types/tsconfig.lib.json" },
    { "path": "../errors/tsconfig.lib.json" },
    { "path": "../logger/tsconfig.lib.json" }
  ]
}
