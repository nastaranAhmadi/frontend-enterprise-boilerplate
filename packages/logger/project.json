{
  "name": "logger",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/logger/src",
  "tags": ["scope:shared", "type:util", "platform:neutral"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc --build tsconfig.lib.json --pretty false",
        "cwd": "packages/logger"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc --build tsconfig.lib.json --pretty false",
        "cwd": "packages/logger"
      }
    }
  }
}
