{
  "name": "landing",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/frontend/landing/src",
  "tags": ["scope:app", "type:app", "platform:web", "domain:frontend"],
  "targets": {
    "build": {
      "executor": "nx:noop",
      "metadata": {
        "description": "Next.js build will be configured in the applications section."
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "tsc -p tsconfig.app.json --noEmit --pretty false",
        "cwd": "apps/frontend/landing"
      }
    }
  }
}
